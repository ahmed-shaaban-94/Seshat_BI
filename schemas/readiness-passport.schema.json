{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seshat-bi.dev/schemas/readiness-passport-1.0.json",
  "title": "Seshat BI Readiness Passport",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "passport_id", "scope", "readiness", "artifacts", "approvals", "validation_boundary", "generated_at", "authority_disclaimer"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "passport_id": {"type": "string", "minLength": 1},
    "source_revision": {"type": ["string", "null"]},
    "scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "readiness": {"type": "array", "items": {"type": "object"}},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "kind", "path", "sha256", "verification"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"},
          "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "verification": {"enum": ["verified", "changed", "missing", "incompatible", "unavailable"]},
          "note": {"type": ["string", "null"]}
        }
      }
    },
    "approvals": {"type": "array", "items": {"type": "object"}},
    "validation_boundary": {"type": "object"},
    "generated_at": {"type": "string", "format": "date-time"},
    "authority_disclaimer": {"type": "string", "minLength": 1}
  }
}
