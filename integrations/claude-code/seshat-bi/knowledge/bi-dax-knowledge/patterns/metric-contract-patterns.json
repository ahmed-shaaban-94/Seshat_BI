        "CC-004",
        "CC-005"
      ]
    },
    {
      "contract_id": "parent_child_hierarchy",
      "intent": "Flatten a self-referencing parent-child hierarchy (e.g. chart of accounts, org chart) into navigable levels.",
      "inputs": [
        "entity_table",
        "entity_key",
        "parent_key",
        "value_measure"
      ],
      "grain": "hierarchy node",
      "additivity": "depends on rollup",
      "filter_behavior": "PATH-based flattening into level columns; browse by level",
      "requires_model_features": [
        "self-referencing key/parent columns"
      ],
      "output": "calculated columns (PATH/levels) + measures",
      "validation_rules": [
        "use PATH/PATHITEM to flatten",
        "handle ragged levels (blank/repeat)",
        "guard depth"
      ],
      "phase_support": [
        "generate",
        "model_review"
      ],
      "maps_to_patterns": [
        "parent-child-hierarchy"
      ],
      "concepts": [
        "CC-002"
      ]
    },
    {
      "contract_id": "transition_matrix",
      "intent": "Classify each entity in two periods and count how many moved between classes (e.g. segment in M-1 vs M).",
      "inputs": [
        "entity_key",
        "class_measure",
        "two time periods",
        "config classes"
      ],
      "grain": "(from-class, to-class) cell",
      "additivity": "non_additive",
      "filter_behavior": "compute class per period, cross-tabulate movement",
      "requires_model_features": [
        "disconnected from/to class axes"
      ],
      "output": "scalar measure over from/to axes",
      "validation_rules": [
        "evaluate class at the right period boundaries",
        "KEEPFILTERS the entity set",
        "no overlapping class ranges"
      ],
      "phase_support": [
        "generate",
        "analyze"
      ],
      "maps_to_patterns": [
        "transition-matrix"
      ],
      "concepts": [
        "CC-003",
        "CC-010"
      ]
    },
    {
      "contract_id": "survey_analysis",
      "intent": "Analyze many-to-many survey answers (respondents x questions x answers) flexibly.",
      "inputs": [
        "answers_fact",
        "respondent_key",
        "question/answer dims",
        "bridge"
      ],
      "grain": "respondent x question",
      "additivity": "non_additive (distinct respondents)",
      "filter_behavior": "route many-to-many via bridge / TREATAS; count distinct respondents",
      "requires_model_features": [
        "bridge or many-to-many between respondents and answers"
      ],
      "output": "scalar measure (distinct respondents)",
      "validation_rules": [
        "count distinct respondents, not answer rows",
        "explicit propagation across the bridge"
      ],
      "phase_support": [
        "generate",
        "analyze",
        "model_review"
      ],
      "maps_to_patterns": [
        "survey-analysis"
      ],
      "concepts": [
        "CC-010",
        "CC-011"
      ]
    },
    {
      "contract_id": "basket_analysis",
      "intent": "Find products frequently bought together (orders containing A that also contain B).",
      "inputs": [
        "sales_fact",
        "order_key",
        "product_key",
        "two product roles (A,B)"
      ],
      "grain": "product pair",
      "additivity": "non_additive",
      "filter_behavior": "self-join via a second disconnected product table applied with TREATAS; count orders",
      "requires_model_features": [
        "disconnected second product table for the 'and also' role"
      ],
      "output": "scalar measure (orders / pairs)",
      "validation_rules": [
        "count distinct orders not lines",
        "exclude the same product as A and B",
        "apply second product set via TREATAS"
      ],
      "phase_support": [
        "generate",
        "analyze"
      ],
      "maps_to_patterns": [
        "basket-analysis"
      ],
      "concepts": [
        "CC-003",
        "CC-010"
      ]
    },
    {
      "contract_id": "budget_vs_actual",
      "intent": "Compare actuals to budget when the two are stored at different granularities.",
      "inputs": [
        "actuals_fact",
        "budget_fact",
        "shared dims at budget grain",
        "value measures"
      ],
      "grain": "the coarser (budget) grain",
      "additivity": "additive within grain",
      "filter_behavior": "align via shared higher-grain dimensions; avoid filtering budget by columns it lacks",
      "requires_model_features": [
        "budget table related only at its grain (e.g. month/category, not day/product)"
      ],
      "output": "scalar measures (Actual, Budget, Variance)",
      "validation_rules": [
        "filter budget only by columns it supports",
        "use TREATAS/shared dims for alignment",
        "guard variance % with DIVIDE"
      ],
      "phase_support": [
        "generate",
        "analyze",
        "model_review"
      ],
      "maps_to_patterns": [
        "budget-vs-actual"
      ],
      "concepts": [
        "CC-010",
        "CC-008"
      ]
