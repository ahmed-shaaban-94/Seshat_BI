model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["gold dim_billing_type","gold dim_branch","gold dim_customer","gold dim_date","gold dim_product","gold dim_salesperson","gold fct_sales"]

annotation PBI_ProTooling = ["MCP-PBIModeling","DevMode"]

ref table 'gold dim_billing_type'
ref table 'gold dim_branch'
ref table 'gold dim_customer'
ref table 'gold dim_date'
ref table 'gold dim_product'
ref table 'gold dim_salesperson'
ref table 'gold fct_sales'

ref cultureInfo en-US

