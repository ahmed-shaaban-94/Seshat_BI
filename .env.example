# DigitalOcean PostgreSQL — analytics database connection.
# Copy to .env and fill in real values. .env is git-ignored; never commit secrets.
# Scope: LOCAL SQL tooling (psql, migrations). Power BI does NOT read this file —
# its credentials live in the Power BI gateway. See docs/powerbi-connection.md.

ANALYTICS_DB_HOST=
ANALYTICS_DB_PORT=25060
ANALYTICS_DB_NAME=
ANALYTICS_DB_USER=
ANALYTICS_DB_PASSWORD=
# DigitalOcean managed Postgres requires TLS.
ANALYTICS_DB_SSLMODE=require

# Multi-engine `retail validate` (Task 11 / R4). Engine selector: postgres
# (default, unset) | sqlserver | mysql | snowflake. All values below are left
# EMPTY here -- fill them only in your own gitignored .env, never here.
ANALYTICS_DB_ENGINE=
# Snowflake account identifier (e.g. <org>-<account>), separate from HOST.
ANALYTICS_DB_ACCOUNT=
# SQL Server ODBC driver name, e.g. "ODBC Driver 18 for SQL Server".
ANALYTICS_DB_ODBC_DRIVER=
# SQL Server: set to true/1/yes to add TrustServerCertificate=yes (dev only).
ANALYTICS_DB_TRUST_CERT=
# Snowflake compute warehouse.
ANALYTICS_DB_WAREHOUSE=
# Snowflake role.
ANALYTICS_DB_ROLE=
