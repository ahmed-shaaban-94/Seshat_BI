# Normalize line endings; Power BI Desktop writes CRLF for PBIP text files.
# Store LF in the repo, check out CRLF on Windows so diffs stay clean.
* text=auto

*.tmdl   text eol=crlf
*.pbir   text eol=crlf
*.pbism  text eol=crlf
*.json   text eol=crlf
*.sql    text eol=lf
*.md     text eol=lf
*.py     text eol=lf
*.toml   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.cfg    text eol=lf

# Workflow scripts are loaded by the Claude Code Workflow tool, which rejects the
# carriage-return byte as a control char -- force LF so they load on Windows checkouts.
.claude/workflows/*.js   text eol=lf

# Generated kit substrate (feature 070) — machine-written projections whose manifest
# checksums are computed over the file bytes, so pin LF for cross-platform
# determinism. Overrides the global `*.json eol=crlf` for this dir only (PBIP JSON
# elsewhere still gets CRLF for Power BI Desktop). Placed last: last match wins.
.seshat/**   text eol=lf

# Public agent bundles and their reviewed templates are byte-for-byte
# deterministic artifacts. Override the global PBIP-oriented JSON CRLF rule so
# fresh Linux and Windows checkouts match the exporter's normalized LF output.
distribution/bundle-templates/**       text eol=lf
integrations/claude-code/seshat-bi/**  text eol=lf
integrations/codex/seshat-bi/**        text eol=lf

# Binary artifacts — never normalize.
*.pbix   binary
*.abf    binary
*.png    binary
*.svg    text eol=lf
docs/rules/rules-manifest.json text eol=lf
docs/rules/severity-posture.json text eol=lf
